@page
@model THPHome.Pages.IndexModel
@using ApplicationCore.Entities;
@using ApplicationCore.Models.Posts;
@{
    int i = 0;
    int j = 0;
    int e = 0;
    int f = 0;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/magnific-popup.min.css" integrity="sha256-PZLhE6wwMbg4AB3d35ZdBF9HD/dI/y4RazA3iRDurss=" crossorigin="anonymous">
<style>
    .play-overlay-center i {
        text-shadow: 0 0 15px rgba(0,0,0,0.5);
        transition: all 0.3s ease;
    }

    .popup-youtube:hover .play-overlay-center i {
        transform: scale(1.1);
        color: #ff0000 !important;
    }
    .carousel-caption {
        z-index: 10;
    }
</style>
<div class="container">
    <div class="row">
        <div class="col-md-8 mb-4">
            <div id="carouselExampleIndicators" class="carousel slide position-relative">
                <div class="carousel-indicators">
                    @foreach (var item in Model.Slides)
                    {
                        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="@j" class="@(j == 0 ? "active" : "")" aria-label="Slide @j" )></button>
                        j++;
                    }
                </div>
                <div class="carousel-inner">
                    @foreach (var item in Model.Slides)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            @if (string.IsNullOrEmpty(item.Url))
                            {
                                <img src="@item.Image" class="d-block w-100" alt="@item.Name">
                            }
                            else
                            {
                                <a href="@item.Url">
                                    <img src="@item.Image" class="d-block w-100" alt="@item.Name">
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(item.Name))
                            {
                                <div class="carousel-overlay">
                                    <div class="carousel-caption">
                                        <a href="@item.Url"><h5>@item.Name</h5></a>
                                        <div class="carousel__overlay--delimiter"></div>
                                        <p>@item.Description</p>
                                    </div>
                                </div>
                            }
                        </div>
                        i++;
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
        <div class="col-md-4  mb-4">
            <div class="title">
                <localize key="operator" />
            </div>
            <div class="row g-2">
                @foreach (var item in Model.BoxMenu)
                {
                    <div class="col-4">
                        <a href="@item.Url" target="_blank">
                            <div class="box shadow-sm">
                                <div class="icon">
                                    @Html.Raw(item.Icon)
                                </div>
                                <div class="name" data-bs-toggle="tooltip" title="@item.Name">@item.Name</div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-md-8 mb-4">
            <a href="https://tuyensinh.dhhp.edu.vn/">
                <img src="https://dhhp.edu.vn/admissions/admission-banner.jpg" alt="Banner" class="w-100" loading="lazy" style="height: 100%; object-fit: contain">
            </a>
        </div>
        <div class="col-md-4 mb-4">
            <div class="title mb-1" style="text-transform: uppercase">
                Điểm tin hàng tháng
            </div>

            @if (Model.VideoBulletins != null && Model.VideoBulletins.Any())
            {
                <div id="carouselVideoBulletins" class="carousel slide border rounded shadow-sm overflow-hidden bg-white" data-bs-ride="carousel">
                    <div class="carousel-indicators">
                        @for (int k = 0; k < Model.VideoBulletins.Count(); k++)
                        {
                            <button type="button" data-bs-target="#carouselVideoBulletins" data-bs-slide-to="@k" class="@(k == 0 ? "active" : "")" aria-label="Slide @k"></button>
                        }
                    </div>

                    <div class="carousel-inner">
                        @{
                            int countBullet = 0;
                        }
                        @foreach (var item in Model.VideoBulletins)
                        {
                            <div class="carousel-item @(countBullet == 0 ? "active" : "")">
                                <a href="https://www.youtube.com/watch?v=@item.YoutubeId" class="popup-youtube position-relative d-block">
                                    <div style="aspect-ratio: 16/9; overflow: hidden; background: #000;">
                                        <img src="https://img.youtube.com/vi/@item.YoutubeId/maxresdefault.jpg"
                                             class="d-block w-100"
                                             alt="Số @item.Volume"
                                             style="height: 100%; object-fit: cover;">

                                        <div class="play-overlay-center" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                                            <i class="fas fa-play-circle fa-4x text-white opacity-75"></i>
                                        </div>
                                    </div>

                                    <div class="carousel-caption" style="background: linear-gradient(transparent, rgba(0,0,0,0.95) 80%); bottom: 0; left: 0; right: 0; padding: 40px 10px 25px 10px;">
                                        <h6 class="mb-1 fw-bold text-uppercase" style="letter-spacing: 0.5px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">
                                            Điểm tin HPUni - Số tháng @item.Volume
                                        </h6>
                                        <small class="text-uppercase" style="font-size: 0.75rem; opacity: 0.9;">
                                            <i class="fas fa-calendar-alt"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                                        </small>
                                    </div>
                                </a>
                            </div>
                            countBullet++;
                        }
                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselVideoBulletins" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselVideoBulletins" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                </div>
            }
            else
            {
                <div class="border rounded p-4 text-center bg-light">
                    <p class="text-muted">Chưa có dữ liệu điểm tin.</p>
                </div>
            }
        </div>
    </div>
</div>

<div class="container">
    <div class="row" data-aos="fade-up">
        <div class="col-md-12">
            @* <div class="title affiliate mb-1 " style="text-transform: uppercase">
                <localize key="affiliate-partner" />
            </div> *@
            @foreach (var item in Model.Blocks)
            {
                @await Component.InvokeAsync(item.ViewComponent, item.Id)
            }
        </div>
    </div>
</div>

<div class="container">
    <div class="row" data-aos="fade-up">

        <div class="col-md-8">
            <div class="title mb-1" style="text-transform: uppercase">
                <localize key="news_and_events" />
            </div>
            <partial name="/Views/Post/_PostsNoPaging.cshtml" model="@Model.ListNews.Take(6)" />
            <div class="related mb-4 border-t">
                @foreach (var item in Model.ListNews.Skip(6))
                {
                    <div class="px-2 py-1 border-b border-r border-l">
                        <i class="fab fa-staylinked mr-1 me-1"></i>
                        <a href="@item.Url">@item.Title</a> <i class="text-muted text-sm">(@item.IssuedDate.ToString("dd/MM/yyyy hh:mm"))</i>
                    </div>
                }
            </div>
        </div>
        <div class="col-md-4 mb-4 flex flex-col">
            <div class="mb-4">
                <partial name="/Views/Shared/_RandomPost.cshtml" model="Model.ListNotification" />
            </div>

            <div class="title mb-1" style="text-transform: uppercase">
                Báo chí nói về chúng tôi
            </div>

            <div id="carouselPressTalks" class="carousel slide h-full border rounded shadow-sm overflow-hidden bg-white">
                <div class="carousel-indicators">
                    @{
                        f = 0;
                    } @foreach (var item in Model.PressTalks)
                    {
                        <button type="button" data-bs-target="#carouselPressTalks" data-bs-slide-to="@f" class="@(f == 0 ? "active" : "")" aria-label="Slide @f"></button>
                        f++;
                    }
                </div>

                <div class="carousel-inner h-full">
                    @{
                        e = 0;
                    } @foreach (var item in Model.PressTalks)
                    {
                        <div class="carousel-item h-full @(e == 0 ? "active" : "")">
                            <div class="flex flex-col h-full">
                                <a href="@item.Url" title="@item.Title" class="bg-black block">
                                    <img src="@item.Thumbnail" class="w-full object-cover transition-opacity hover:opacity-75" alt="@item.Title" style="height: 180px;" />
                                </a>

                                <div class="p-3 flex-1">
                                    <a href="@item.Url" title="@item.Title" class="line-clamp-2 font-bold text-dark mb-2" style="text-decoration:none; font-size: 1.1rem;">
                                        @item.Title
                                    </a>
                                    <div class="text-muted line-clamp-3 text-sm">
                                        @item.Description
                                    </div>
                                </div>

                                <div class="bg-light p-2 mt-auto border-top flex justify-between items-center text-muted" style="font-size: 0.8rem;">
                                    <span><i class="fas fa-clock mr-1"></i> @item.IssuedDate.ToString("dd/MM/yyyy")</span>
                                    <span><i class="fa fa-eye mr-1"></i> @item.View.ToString("N0")</span>
                                </div>
                            </div>
                        </div>
                        e++;
                    }
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#carouselPressTalks" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselPressTalks" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            </div>
        </div>
    </div>

</div>

<div class="container">
    <div class="row g-2">
        @foreach (var item in Model.GroupCategories)
        {
            <div class="col-md-4 mb-4">
                <div class="title"><a href="/category/details/@item.Id" class="text-dark">@item.Name</a></div>
                <div class="category-box">
                    <div class="list-group">
                        @foreach (var cat in item.Childs)
                        {
                            <a href="/category/details/@cat.Id" class="list-group-item list-group-item-action"><i class="fas fa-caret-right mr-2"></i>@cat.Name</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

</div>

<div class="mb-4 statistics">
    <div class="grid md:grid-cols-4 grid-cols-2 counter-wrapper">
        <div class="flex flex-col">
            <div class="head">
                <span class="counter" data-count="15">0</span>K+
            </div>
            <div class="des" data-aos="fade-up">
                Sinh viên đang theo học
            </div>
        </div>
        <div class="flex flex-col">
            <div class="head">
                <span class="counter" data-count="97">0</span>%
            </div>
            <div class="des" data-aos="fade-up">
                Sinh viên có việc làm
            </div>
        </div>
        <div class="flex flex-col">
            <div class="head">
                <span class="counter" data-count="50">0</span>+
            </div>
            <div class="des" data-aos="fade-up">
                Chương trình đào tạo
            </div>
        </div>
        <div class="flex flex-col">
            <div class="head">
                <span class="counter" data-count="10">0</span>+
            </div>
            <div class="des" data-aos="fade-up">
                Lĩnh vực đào tạo
            </div>
        </div>
    </div>

</div>

<div class="container">
    <div class="media">
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home" type="button" role="tab" aria-controls="home" aria-selected="true">
                    <localize key="playlist" />
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="false">
                    <localize key="gallery" />
                </button>
            </li>
        </ul>
        <div class="tab-content" id="myTabContent">
            <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab">
                <div class="row">
                    <div class="col-md-8 mb-4">
                        <div id="player" data-plyr-provider="youtube" data-plyr-embed-id="https://www.youtube.com/embed/@Model.Videos.FirstOrDefault()?.Url"></div>
                    </div>
                    <div class="col-md-4 mb-4">
                        @foreach (var item in Model.Videos)
                        {
                            <div class="flex items-center">
                                <div class="bg-dark" style="width: 100px">
                                    <img src="https://img.youtube.com/vi/@item.Url/0.jpg" alt="IMG" style="width: 100px; height: 70px; object-fit: cover" class="transition duration-700 hover:opacity-75" onclick="playVideo('@item.Url')" />
                                </div>
                                <div class="p-2" onclick="playVideo('@item.Url')" style="width: calc(100% - 100px);">
                                    <div class="font-bold hover:text-blue-500 cursor-pointer">@item.Name</div>
                                    <div class="text-muted text-sm">@item.CreatedDate</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                <div class="row g-2 gallery mb-2">
                    @foreach (var item in Model.Albums)
                    {
                        <div class="col-6 col-md-3 mb-4">
                            <div class="bg-dark">
                                <a href="@item.Url" class="image-popup">
                                    <img src="@item.Url" alt="@item.Description" class="transition duration-700 hover:opacity-75 w-full md:h-80 h-32" style="object-fit: cover;" />
                                </a>
                            </div>
                        </div>
                    }
                </div>
                <div class="d-flex justify-content-center">
                    <a href="/albums" class="btn btn-outline-primary text-uppercase"><i class="fa-solid fa-arrow-left"></i> Xem tất cả <i class="fa-solid fa-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/jquery.magnific-popup.min.js" integrity="sha256-P93G0oq6PBPWTP1IR8Mz/0jHHUpaWL0aBJTKauisG7Q=" crossorigin="anonymous"></script>
    <script src="~/js/album/album.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/waypoints/3.0.1/jquery.waypoints.js"></script>
    <script src="https://bfintal.github.io/Counter-Up/jquery.counterup.min.js"></script>
    <script>
        $('.counter').each(function () {
            var $this = $(this),
                countTo = $this.attr('data-count');
            $({ countNum: $this.text() }).animate({
                countNum: countTo
            }, {
                duration: 8000,
                easing: 'linear',
                step: function () {
                    $this.text(Math.floor(this.countNum));
                },
                complete: function () {
                    $this.text(this.countNum);
                }
            });
        });
        const player = new Plyr('#player');
        function playVideo(url) {
            player.source = {
                type: 'video',
                title: 'Example title',
                sources: [
                    {
                        src: url,
                        provider: 'youtube'
                    }
                ]
            };

            player.play();
        }
    </script>
    <script>
        $(document).ready(function() {
            $('.popup-youtube').magnificPopup({
                type: 'iframe',
                mainClass: 'mfp-fade',
                removalDelay: 160,
                preloader: false,
                fixedContentPos: false
            });
        });
    </script>
}
