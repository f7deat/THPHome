@model WebUI.Models.Blocks.PopupBlock

@if (Model != null)
{
    <div class="modal fade" id="popupModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 bg-transparent text-center d-table mx-auto">
                <div class="position-relative d-inline-block">
                    <button type="button"
                            class="btn-close position-absolute top-0 end-0 m-5 z-3"
                            style="filter: invert(1); opacity: 1;" 
                            data-bs-dismiss="modal"></button>

                    <img src="@Model.Image"
                         class="img-fluid"
                         style="max-height: 80vh; width: auto; object-fit: contain; display: block;" />
                </div>
            </div>
        </div>
    </div>
}